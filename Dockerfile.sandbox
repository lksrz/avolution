# Avolution — minimal sandbox image
# Alpine + Node (claude CLI) + Python (predictor scripts)

FROM node:22-alpine

# Python + pip + common predictor deps
RUN apk add --no-cache python3 py3-pip && \
    pip3 install --break-system-packages requests && \
    npm install -g @anthropic-ai/claude-code

# node:22-alpine already has uid 1000 as 'node' — reuse it
USER node
WORKDIR /workspace
ENTRYPOINT ["claude"]
